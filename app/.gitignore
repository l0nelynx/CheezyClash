/build
*.iml
*.txt
/release

# Baseline Profile артефакты должны коммититься — это входные данные для release-сборки,
# а не build output. Канон: src/directRelease/generated/baselineProfiles/ (shared open+proprietary).
# Генерация: `gradlew :app:generateDirectOpenReleaseBaselineProfile` затем
# `gradlew :app:promoteBaselineProfileToDirectRelease`.
!src/*/generated/baselineProfiles/baseline-prof.txt
!src/*/generated/baselineProfiles/startup-prof.txt
