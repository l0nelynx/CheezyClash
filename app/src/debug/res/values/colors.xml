<?xml version="1.0" encoding="utf-8"?>
<!--
    Debug-overlay для цветов launcher-иконки. AGP мерджит src/debug/res поверх
    src/main/res в debug-сборке (значение тут перекроет main/values/colors.xml).
    В release не попадает — основной цвет остаётся как в main.

    Меняем только сам "сыр" (ic_launcher_cheese), чтобы визуально отличать
    debug-иконку на лаунчере. mast и background не трогаем — пусть остаются
    как в main, иначе иконка станет полностью красной и потеряет узнаваемость.

    Mipmap-варианты (mipmap-hdpi/.webp и т.д.) пересчитываются ART-ом из
    adaptive-icon XML, ничего дополнительно перерисовывать не нужно.
-->
<resources>
    <color name="ic_launcher_cheese">#FF000000</color>
    <color name="ic_launcher_background">#D32F2F</color>
    <color name="ic_launcher_mast">#FF000000</color>
    <color name="ic_launcher_stroke">#FF000000</color>
</resources>
