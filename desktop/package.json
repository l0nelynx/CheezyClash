{
  "name": "cheezyclash-desktop",
  "productName": "CheezyClash",
  "version": "1.5.30",
  "description": "CheezyClash desktop client for Mihomo (Clash.Meta)",
  "main": "./out/main/index.js",
  "homepage": "https://github.com/l0nelynx/CheezyClash",
  "author": {
    "name": "l0nelynx",
    "email": "113856580+l0nelynx@users.noreply.github.com"
  },
  "license": "GPL-3.0-or-later",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "icons": "node scripts/rasterize-icons.mjs",
    "sync-version": "node scripts/sync-version.mjs",
    "package": "npm run sync-version && npm run icons && npm run build && electron-builder --dir",
    "dist": "npm run sync-version && npm run icons && npm run build && electron-builder",
    "dist:win": "npm run sync-version && npm run icons && npm run build && electron-builder --win",
    "dist:linux": "npm run sync-version && npm run icons && npm run build && electron-builder --linux",
    "dist:mac": "npm run sync-version && npm run icons && npm run build && electron-builder --mac",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "fetch-core": "node scripts/fetch-core.mjs",
    "build-core": "node scripts/build-core.mjs",
    "build:helper": "node scripts/build-helper.mjs",
    "smoke": "node scripts/smoke-proxy.mjs"
  },
  "dependencies": {
    "country-flag-emoji-polyfill": "^0.1.8",
    "electron-store": "^8.2.0",
    "js-yaml": "^4.1.0",
    "lucide-react": "^1.25.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@resvg/resvg-js": "^2.6.2",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.3",
    "@types/babel__core": "^7.20.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.9.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "43.1.1",
    "electron-builder": "^27.0.0-alpha.5",
    "electron-vite": "^6.0.0-beta.1",
    "rcedit": "^5.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.8.2",
    "vite": "^8.1.5"
  },
  "build": {
    "extends": "./electron-builder.yml"
  }
}
